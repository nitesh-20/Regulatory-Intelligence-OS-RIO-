# pyenv
#   For a library or package, you might want to ignore these files since the values are
#   specific to the developer's environment, not the project.
# .python-version

# pipenv
#   According to pypa/pipenv#1263, we should ignore Pipfile.lock in templates, but not in apps.
#Pipfile.lock

# poetry
#   According to poetry docs, the poetry.lock file should be tracked in version control.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, PDM's lockfile in libraries should be ignored, but in applications it should be tracked.
#.pdm-python.cache/
#.pdm-build/

# PEP 582; project local packages (e.g. pdm)
__pypackages__/

