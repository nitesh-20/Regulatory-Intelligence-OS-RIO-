{
  "name": "rio-agent-monorepo",
  "version": "1.0.0",
  "description": "RIO Agent - Agentic Regulatory Intelligence Platform",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "bootstrap": "npm install --workspace=frontend && pip install -r backend/requirements.txt",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --port 8000",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
